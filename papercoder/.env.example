# ── LLM 配置 ────────────────────────────────────────────────────
# 选择提供商：gemini（默认）/ anthropic / openai
MODEL_PROVIDER=gemini

# Google Gemini（推荐，免费额度大）
# 获取：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic Claude（备用）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI GPT（备用）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ── 检索工具 ─────────────────────────────────────────────────────
# Tavily 网络搜索（在 https://tavily.com 免费注册）
TAVILY_API_KEY=your_tavily_api_key_here

# GitHub Token（代码仓库检索）
# 获取：GitHub → Settings → Developer settings → Personal access tokens
# 只需勾选 public_repo 权限
GITHUB_TOKEN=your_github_personal_access_token_here

# Semantic Scholar（可选，无 key 时使用公开 API，有速率限制）
# SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here

# ── 可观测性（LangSmith，可选）────────────────────────────────────
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=papercoder
